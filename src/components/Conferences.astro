                    <div class="relative text-center px-4">
                      <p class="text-white font-black text-3xl md:text-4xl tracking-tight drop-shadow-lg leading-none">
                        {c.eventAbbreviation}
                      </p>
                      <p class="text-white/70 font-semibold text-sm mt-1.5 tracking-wide">
                        {getYear(c.date)}
