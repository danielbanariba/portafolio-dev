                    class="inline-flex items-center gap-1.5 text-xs font-medium text-gray-300 hover:text-blue-400 bg-gray-700/50 hover:bg-gray-700 px-3 py-1.5 rounded transition-all duration-200"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <circle cx="15" cy="15" r="3" />
                      <path d="M13.4 10.5a5 5 0 0 0-5.9 5.9" />
                      <path d="M10 19H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v5" />
                      <path d="m13 17 2 2 4-4" />
                    </svg>
                    Ver certificado
                  </a>
                )}
                {featured.slidesUrl && (
                  <a
                    href={featured.slidesUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 text-xs font-medium text-gray-300 hover:text-blue-400 bg-gray-700/50 hover:bg-gray-700 px-3 py-1.5 rounded transition-all duration-200"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <rect x="2" y="3" width="20" height="14" rx="2" />
                      <line x1="8" y1="21" x2="16" y2="21" />
                      <line x1="12" y1="17" x2="12" y2="21" />
                    </svg>
                    Slides
                  </a>
                )}
                {featured.videoUrl && (
                  <a
                    href={featured.videoUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 text-xs font-medium text-gray-300 hover:text-blue-400 bg-gray-700/50 hover:bg-gray-700 px-3 py-1.5 rounded transition-all duration-200"
