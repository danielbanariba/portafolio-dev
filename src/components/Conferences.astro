                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polygon points="23 7 16 12 23 17 23 7" />
                      <rect x="1" y="5" width="15" height="14" rx="2" ry="2" />
                    </svg>
                    Grabación
                  </a>
                )}
                {featured.eventUrl && (
                  <a
                    href={featured.eventUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="ml-auto inline-flex items-center gap-1.5 text-xs font-medium text-gray-300 hover:text-blue-400 transition-colors duration-200"
                  >
                    <span>Sitio del evento</span>
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                      <polyline points="15 3 21 3 21 9" />
                      <line x1="10" y1="14" x2="21" y2="3" />
                    </svg>
                  </a>
                )}
              </div>
            </div>
          </div>
        </article>
      )
    }

    {
      visibleCompact.length > 0 && (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {visibleCompact.map((c) => {
            const theme = getCardTheme(c);
            return (
              <article class="conference-card relative bg-gray-800 rounded-lg overflow-hidden z-[1] flex flex-col">
                <div
                  class={`${theme.bgClass} relative h-40 flex items-center justify-center overflow-hidden`}
